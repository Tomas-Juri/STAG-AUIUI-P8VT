@model EventSourcing.Mvc.Models.Home.IndexModel

@{
    ViewData["Title"] = "Shippers";
}

<section class="py-5 my-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <header>
                <h2 class="h1">My Orders</h2>
                <p class="mb-0">
                    Get the overview of your last orders.
                </p>
            </header>
            <div class="d-flex gap-2">
                <a class="btn btn-secondary">Show all my orders</a>
                <a class="btn btn-primary" asp-controller="Orders" asp-action="ViewNewOrder">Create new order</a>
            </div>
        </div>
        <div class="row">
            @foreach (var order in Model.MyOrders)
            {
                
                <div class="col-3">
                    <div class="card mb-3">
                        <img src="@order.PhotoUrl" class="card-img-top" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">@order.Name</h5>
                            <p class="card-text">@order.Description</p>
                            <p class="card-text">
                                <small class="text-muted">Last updated @order.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>